# MissionOS server
PORT=3001
NODE_ENV=production
# Required in production. Use a random value at least 32 characters long.
JWT_SECRET=replace-with-a-long-random-secret
# Leave blank for same-origin production use, or set a comma-separated allowlist.
CORS_ALLOWED_ORIGINS=

# Runtime / integration endpoints
OFFICE_URL=http://localhost:3001
# When set, the MissionOS server will poll this OpenClaw host directly.
# Point this at any reachable OpenClaw host: LAN IP, Tailscale IP, or DNS name.
OPENCLAW_URL=http://192.168.1.113:18789
# Optional bearer token if your OpenClaw gateway requires auth.
OPENCLAW_TOKEN=
HERMES_URL=
HERMES_WS_URL=
HERMES_RUNTIME_URL=
HERMES_TOKEN=
LINEAR_API_URL=https://api.linear.app/graphql
LINEAR_API_KEY=
LINEAR_SYNC_INTERVAL_MS=30000

# Deployed target smoke test
MISSIONOS_TARGET_URL=
MISSIONOS_TARGET_USERNAME=
MISSIONOS_TARGET_PASSWORD=
