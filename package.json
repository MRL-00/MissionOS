{
  "name": "missionos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "cd server && node --watch-path=./src --watch-path=./tsconfig.json --watch-path=../package.json --watch-preserve-output --import tsx ./src/index.ts",
    "build": "vite build && rm -rf server/dist && tsc -p server/tsconfig.build.json",
    "start": "NODE_ENV=production node server/dist/index.js",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "check:scripts": "bash -n scripts/*.sh && for file in scripts/*.js; do node --check \"$file\" || exit $?; done && tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --types node scripts/agent-runtime-bridge.ts",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test:client": "vitest run",
    "clean:test-data": "node scripts/clean-test-data.js",
    "test:server": "node --test --import tsx \"server/src/**/*.test.ts\" \"scripts/**/*.test.js\"; status=$?; pnpm clean:test-data; exit $status",
    "test": "pnpm test:client && pnpm test:server",
    "smoke:production": "node scripts/production-smoke.js",
    "smoke:docker": "node scripts/docker-smoke.js",
    "smoke:compose": "node scripts/compose-smoke.js",
    "smoke:target": "node scripts/target-smoke.js",
    "release:check": "pnpm check:scripts && pnpm typecheck && pnpm test && pnpm build && pnpm smoke:production && pnpm audit",
    "release:docker": "JWT_SECRET=ci-compose-secret-with-enough-length docker compose config --quiet && docker build --build-arg VITE_DEPLOY_VERSION=${VITE_DEPLOY_VERSION:-ci} -t missionos:ci . && pnpm smoke:docker && pnpm smoke:compose",
    "db:backup": "node scripts/backup-db.js",
    "db:restore": "node scripts/restore-db.js",
    "db:reset": "node scripts/reset-db.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-popover": "^1.1.15",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "emoji-picker-react": "^4.18.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.27",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "shadcn": "4.11.0",
    "tailwindcss": "^4.3.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "qs": "6.15.2"
    }
  },
  "packageManager": "pnpm@10.17.0"
}
