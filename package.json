{
  "name": "the-office",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:full": "pnpm dev",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "tsx server/server.ts",
    "dev:bridge": "tsx scripts/agent-runtime-bridge.ts",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test:server": "node --import tsx --test server/*.test.ts",
    "test:client": "vitest run",
    "test": "pnpm test:server && pnpm test:client"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.17.0"
}
