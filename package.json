{
  "name": "the-office",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:full": "pnpm dev",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "tsx server/server.ts",
    "dev:sync": "tsx scripts/office-sync.ts",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test:server": "node --import tsx --test server/workflow.test.ts"
  },
  "dependencies": {
    "three": "^0.179.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@types/ws": "^8.18.1",
    "@types/three": "^0.183.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.3"
  },
  "packageManager": "pnpm@10.17.0"
}
